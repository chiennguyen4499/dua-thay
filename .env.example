# Copy file này thành .env và điền thông tin của bạn

# Token Telegram Bot (lấy từ @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Chat ID của bạn (lấy bằng cách nhắn /start cho bot rồi xem log)
# Để trống nếu muốn cho phép mọi người dùng
ALLOWED_CHAT_ID=

# Đường dẫn database
DATABASE_PATH=data/rounds.db

# Số trận tối thiểu để dùng thống kê pattern (ít hơn thì dùng ước tính)
MIN_SAMPLES_FOR_PATTERN=3

# Turso (database online dùng chung giữa bot trên PC và Web UI trên Streamlit
# Cloud) — lấy từ dashboard Turso sau khi tạo database. Để trống nếu chỉ chạy
# local (hệ thống tự dùng SQLite ở DATABASE_PATH).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
